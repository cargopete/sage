// MCP DevOps Assistant — RFC-0023 Showcase
//
// A multi-agent system that uses MCP tools to monitor a GitHub repository,
// analyse open issues with LLM-powered triage, and write status reports
// to the local filesystem.
//
// Demonstrates:
//   - Typed MCP tool declarations (Github, Filesystem)
//   - Tool usage from agents (use Github, use Filesystem)
//   - LLM-powered analysis via divine
//   - Parallel agent summoning
//   - Persistent state across restarts
//   - Supervisor tree for resilience
//   - Dynamic MCP via mcp_connect / mcp_call
//
// Run with: sage run examples/mcp_devops/
// (Requires GITHUB_TOKEN env var and Node.js for npx)

// ---------------------------------------------------------------------------
// MCP Tool Declarations
// ---------------------------------------------------------------------------

tool Github {
    fn search_repositories(query: String) -> String
    fn list_issues(owner: String, repo: String) -> String
    fn get_issue(owner: String, repo: String, issue_number: Int) -> String
    fn create_issue(owner: String, repo: String, title: String, body: String) -> String
}

tool Filesystem {
    fn write_file(path: String, content: String) -> String
    fn read_file(path: String) -> String
    fn list_directory(path: String) -> String
}

// ---------------------------------------------------------------------------
// Issue Scanner — fetches open issues from a repository
// ---------------------------------------------------------------------------

agent IssueScanner {
    use Github

    owner: String
    repo: String

    on start {
        print("Scanning issues for {self.owner}/{self.repo}...");

        let raw = try Github.list_issues(self.owner, self.repo);

        // Extract a summary: how many issues, their titles
        let summary = try divine(
            "Given this JSON list of GitHub issues, produce a brief numbered list of the first 5 issue titles with their numbers. If there are more than 5, note how many total. Keep it concise. JSON: {raw}"
        );

        print("Issue scan complete.");
        yield(summary);
    }

    on error(e) {
        print("Issue scan failed: {e}");
        yield("Issue scan unavailable");
    }
}

// ---------------------------------------------------------------------------
// Repo Analyser — searches for a repository and summarises it
// ---------------------------------------------------------------------------

agent RepoAnalyser {
    use Github

    query: String

    on start {
        print("Searching repositories for: {self.query}...");

        let results = try Github.search_repositories(self.query);

        let analysis = try divine(
            "Given these GitHub search results, summarise the top 3 repositories found. For each, give the name, star count, and a one-line description. Keep it compact. JSON: {results}"
        );

        yield(analysis);
    }

    on error(e) {
        print("Repo analysis failed: {e}");
        yield("Repository search unavailable");
    }
}

// ---------------------------------------------------------------------------
// Report Writer — writes findings to the filesystem via MCP
// ---------------------------------------------------------------------------

agent ReportWriter {
    use Filesystem

    report_content: String
    filename: String

    on start {
        print("Writing report to {self.filename}...");

        let header = "# DevOps Report\n\nGenerated by Sage MCP DevOps Assistant\n\n";
        let full_report = header ++ self.report_content;

        try Filesystem.write_file(self.filename, full_report);

        print("Report written successfully.");
        yield(self.filename);
    }

    on error(e) {
        print("Report write failed: {e}");
        yield("failed");
    }
}

// ---------------------------------------------------------------------------
// Dynamic MCP Demo — connects to an MCP server at runtime
// ---------------------------------------------------------------------------

agent DynamicExplorer {
    config_json: String

    on start {
        print("Connecting to MCP server dynamically...");

        let handle = try mcp_connect(self.config_json);
        let tools_json = try mcp_list_tools(handle);

        let summary = try divine(
            "List the tool names available from this MCP server. Just the names, one per line. JSON: {tools_json}"
        );

        try mcp_disconnect(handle);

        print("Dynamic MCP exploration complete.");
        yield(summary);
    }

    on error(e) {
        print("Dynamic MCP exploration failed: {e}");
        yield("Dynamic exploration unavailable");
    }
}

// ---------------------------------------------------------------------------
// Coordinator — orchestrates the full DevOps workflow
// ---------------------------------------------------------------------------

agent Coordinator {
    @persistent runs_completed: Int

    on waking {
        trace("Coordinator restored, " ++ int_to_str(self.runs_completed.get()) ++ " previous runs");
    }

    on start {
        let run_number = self.runs_completed.get() + 1;
        self.runs_completed.set(run_number);

        print("");
        print("=== MCP DevOps Assistant (Run #{run_number}) ===");
        print("");

        // Phase 1: Parallel issue scanning and repo search
        span "mcp_operations" {
            let scanner = summon IssueScanner {
                owner: "anthropics",
                repo: "claude-code"
            };

            let analyser = summon RepoAnalyser {
                query: "language:sage agents"
            };

            let issues = try await scanner;
            let repos = try await analyser;

            print("");
            print("--- Open Issues ---");
            print(issues);
            print("");
            print("--- Related Repositories ---");
            print(repos);

            // Phase 2: Generate and write a combined report
            let report = "## Issues\n\n" ++ issues ++ "\n\n## Related Repos\n\n" ++ repos;
            let writer = summon ReportWriter {
                report_content: report,
                filename: "/tmp/sage-devops/report.md"
            };
            let report_path = try await writer;
            print("");
            print("Report saved to: {report_path}");
        }

        // Phase 3: Dynamic MCP exploration
        span "dynamic_mcp" {
            let fs_config = '{"transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}';
            let explorer = summon DynamicExplorer {
                config_json: fs_config
            };
            let available_tools = try await explorer;
            print("");
            print("--- Dynamically Discovered Tools ---");
            print(available_tools);
        }

        print("");
        print("=== DevOps run #{run_number} complete ===");
        yield("done");
    }

    on resting {
        trace("Coordinator shutting down, state persisted");
    }

    on error(e) {
        print("DevOps pipeline failed: {e}");
        yield("error");
    }
}

// ---------------------------------------------------------------------------
// Supervisor — keeps the coordinator alive
// ---------------------------------------------------------------------------

supervisor DevOpsSupervisor {
    strategy: OneForOne
    children {
        Coordinator {
            restart: Permanent
            runs_completed: 0
        }
    }
}

run DevOpsSupervisor;
